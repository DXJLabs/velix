# Frontend wallet/auth.
VITE_PRIVY_APP_ID=
VITE_PRIVY_LOGIN_METHODS=email,google
# Shared direct-helper testnet AES fallback. If omitted, the browser creates a
# per-device localStorage key for direct-helper demos. Production Shield should
# provide Privacy Pool-derived encryption instead.
VITE_VEIL_CHANNEL_KEY=
VITE_VEIL_ONCHAIN_PAYLOADS=false
VITE_AVNU_PAYMASTER_ENABLED=true

# Server-side Privy Starknet signer. Configure these in Vercel project settings, never in the browser.
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_VERIFICATION_KEY=
AVNU_PAYMASTER_API_KEY=
AVNU_PAYMASTER_NODE_URL=https://sepolia.paymaster.avnu.fi

# Starknet network and contracts.
VITE_STARKNET_CHAIN_ID=SN_SEPOLIA
VITE_STARKNET_RPC_URL=https://api.zan.top/public/starknet-sepolia/rpc/v0_9
VITE_PRIVY_STARKNET_RPC_URL=https://api.zan.top/public/starknet-sepolia/rpc/v0_9
VITE_PRIVACY_POOL_ADDRESS=0x03a91bc44040f4173f30f3233d3cb2510aa05a0b74c22a5ee8240a313a0c8de5
VITE_VEIL_CHANNEL_HELPER_ADDRESS=0x052390845931a0c8d4735246d853a1a514c3cbf88cb1714937284814c5e57b23
VITE_VEIL_OFFER_ADDRESS=0x02f31ea76073dbf57f404513d2160fb0ca81d6d7432be594be10cca37441feab
VITE_VEIL_ESCROW_ADDRESS=0x039922336d0a0fbcbf765bc9c8a5992eb62dabfe80e59d0773b70a172aacd53a
VITE_VEIL_SETTLEMENT_HELPER_ADDRESS=0x04b327c028534000e87512ac962cb0f30f72f215632b88dd39282ad7ded5ef65
VITE_DEMO_COUNTERPARTY_ADDRESS=
VEIL_INDEXER_FROM_BLOCK=0

# Timeline transport mode.
# mock = local in-memory demo only.
# direct-helper = submit encrypted timeline references directly to VeilChannelHelper on testnet.
# privacy-pool = AVNU/Starknet Privacy SDK path through Privacy Pool InvokeExternal.
VITE_VEIL_TIMELINE_MODE=direct-helper
