# Frontend wallet/auth.
VITE_PRIVY_APP_ID=
VITE_PRIVY_LOGIN_METHODS=email,google
# Legacy static channel keys are ignored by encrypted-direct messaging.
VITE_VEIL_ONCHAIN_PAYLOADS=false
# Paymaster submission is security-disabled until proof-aware compatibility is verified.
VITE_AVNU_PAYMASTER_ENABLED=false

# Server-side Privy Starknet signer. Configure these in Vercel project settings, never in the browser.
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_VERIFICATION_KEY=
AVNU_PAYMASTER_API_KEY=
AVNU_PAYMASTER_NODE_URL=https://sepolia.paymaster.avnu.fi

# Starknet network and contracts. Runtime is Sepolia-only and rejects other chains.
VITE_STARKNET_CHAIN_ID=SN_SEPOLIA
VITE_STARKNET_RPC_URL=https://api.zan.top/public/starknet-sepolia/rpc/v0_9
VITE_PRIVY_STARKNET_RPC_URL=https://api.zan.top/public/starknet-sepolia/rpc/v0_9
VITE_PRIVACY_POOL_ADDRESS=0x03a91bc44040f4173f30f3233d3cb2510aa05a0b74c22a5ee8240a313a0c8de5
VITE_VEIL_CHANNEL_HELPER_ADDRESS=0x052390845931a0c8d4735246d853a1a514c3cbf88cb1714937284814c5e57b23
VITE_VEIL_KEY_REGISTRY_ADDRESS=
VITE_VEIL_KEY_REGISTRY_CHAIN_ID=SN_SEPOLIA
# The deployed offer predates the hardened source and cannot be enabled.
VITE_VEIL_OFFER_ADDRESS=
VITE_VEIL_ESCROW_ADDRESS=
# The deployed legacy escrow and settlement helper are unsafe/incomplete and cannot be enabled.
VITE_VEIL_UNSAFE_SETTLEMENT_ENABLED=false
VITE_VEIL_SETTLEMENT_HELPER_ADDRESS=
VITE_DEMO_COUNTERPARTY_ADDRESS=
VEIL_INDEXER_CURSOR_SECRET=
VEIL_INDEXER_CONFIRMATIONS=12
VEIL_INDEXER_REORG_OVERLAP=32

# STRK20 privacy runtime. The official SDK foundation is installed; production bootstrap remains E2E-blocked.
VITE_STRK20_SDK_ENABLED=false
VITE_STRK20_PROVER_MODE=disabled
VITE_STRK20_PROVER_URL=
# contract = development RPC discovery; indexer requires VITE_STRK20_DISCOVERY_URL.
VITE_STRK20_DISCOVERY_PROVIDER=contract
VITE_STRK20_DISCOVERY_URL=
# The verified legacy Sepolia Pool predates screening support.
VITE_STRK20_SCREENING_CAPABLE=false
VITE_STRK20_SCREENING_PROVIDER=none
VITE_STRK20_SCREENING_URL=

# Timeline transport mode.
# mock = local in-memory demo only.
# direct-helper = submit encrypted timeline references directly to VeilChannelHelper on testnet.
# privacy-pool = AVNU/Starknet Privacy SDK path through Privacy Pool InvokeExternal.
VITE_VEIL_TIMELINE_MODE=direct-helper
