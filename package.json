{
  "name": "veil-ux-prototype",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "npm run typecheck && vite build",
    "build:sdk": "tsc -p packages/veil-sdk/tsconfig.json",
    "test:sdk": "npm run build:sdk && node --test packages/veil-sdk/tests/*.test.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "npm run build:sdk && tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.17",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^7.0.0"
  },
  "dependencies": {
    "@privy-io/node": "^0.23.0",
    "@privy-io/react-auth": "^3.32.2",
    "@solana-program/memo": "^0.10.0",
    "@solana-program/system": "^0.10.0",
    "@solana-program/token": "^0.9.0",
    "@solana/kit": "^5.5.1",
    "ethers": "^6.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "starkzap": "^3.0.0",
    "swr": "^2.4.2"
  }
}
